{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "SCSS: watch",
      "type": "npm",
      "script": "watch:css:poll",
      "problemMatcher": {
        "owner": "sass",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Sass is watching for changes"
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "SCSS: watch (native FS)",
      "type": "npm",
      "script": "watch:css",
      "problemMatcher": {
        "owner": "sass",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Sass is watching for changes"
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
